# =============================================================================
# CTSpinoPelvic1K  —  default.env
#
# Canonical paths and pipeline parameters.  Sourced by every SLURM script so
# that hard-coded paths live in exactly one place.
#
# Override any of these at submit time:
#     DATA_DIR=/scratch/$USER/ctspine make download-raw
# =============================================================================

# ── Paths ────────────────────────────────────────────────────────────────────
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
DATA_DIR="${DATA_DIR:-${PROJECT_ROOT}/data}"
LOGS_DIR="${LOGS_DIR:-${PROJECT_ROOT}/logs}"

# Raw-data subdirs
TCIA_DIR="${TCIA_DIR:-${DATA_DIR}/tcia}"
CTSPINE1K_DIR="${CTSPINE1K_DIR:-${DATA_DIR}/ctspine1k}"
CTPELVIC1K_DIR="${CTPELVIC1K_DIR:-${DATA_DIR}/ctpelvic1k}"

# Intermediate artifacts
PATIENT_DB="${PATIENT_DB:-${DATA_DIR}/patient_db.json}"
NIFTI_DIR="${NIFTI_DIR:-${DATA_DIR}/tcia_nifti}"
PLACED_DIR="${PLACED_DIR:-${DATA_DIR}/placed}"
PLACED_MANIFEST="${PLACED_MANIFEST:-${DATA_DIR}/placed/placed_manifest.json}"

# Output
HF_EXPORT_DIR="${HF_EXPORT_DIR:-${DATA_DIR}/hf_export}"

# ── Containers (two .sif files from Docker Hub, via slurm/hpc_pull.sh) ──────
# Lean image used by Stages 1-3 + all utility scripts.
SIF_PATH="${SIF_PATH:-${PROJECT_ROOT}/containers/ctspinopelvic1k.sif}"
# CUDA image used only by Stage 4 (TotalSegmentator benchmark).
TS_SIF_PATH="${TS_SIF_PATH:-${PROJECT_ROOT}/containers/ctspinopelvic1k-ts.sif}"

# ── Parallelism ──────────────────────────────────────────────────────────────
WORKERS="${WORKERS:-${SLURM_CPUS_PER_TASK:-16}}"
DCM2NIIX_WORKERS="${DCM2NIIX_WORKERS:-16}"
HF_WORKERS="${HF_WORKERS:-8}"

# ── HuggingFace ──────────────────────────────────────────────────────────────
# No default repo: the export is pushed to several venue repos, so the
# target must be supplied at invocation (HF_REPO_ID=org/Name). Empty here.
HF_REPO_ID="${HF_REPO_ID:-}"
HF_TOKEN="${HF_TOKEN:-}"
HF_PRIVATE="${HF_PRIVATE:-0}"

# ── Stage 2 debug controls ───────────────────────────────────────────────────
DEBUG_N="${DEBUG_N:-0}"
DEBUG_TOKENS="${DEBUG_TOKENS:-}"

# ── Stage 3 export controls ──────────────────────────────────────────────────
SKIP_QC="${SKIP_QC:-0}"
NO_PIR="${NO_PIR:-0}"
SKIP_EXPORT="${SKIP_EXPORT:-0}"
PUSH="${PUSH:-0}"

# ── Thresholds ───────────────────────────────────────────────────────────────
# Bone HU threshold (used in place_fused_masks.py for cross-correlation)
BONE_HU_MIN="${BONE_HU_MIN:-200}"

# Minimum bone_pct for placement QC flags
SPINE_BONE_PCT_MIN="${SPINE_BONE_PCT_MIN:-40}"
PELVIC_BONE_PCT_MIN="${PELVIC_BONE_PCT_MIN:-15}"

# ── Singularity runtime dirs ─────────────────────────────────────────────────
export SINGULARITY_TMPDIR="/tmp/${USER}_job_${SLURM_JOB_ID}"
export XDG_RUNTIME_DIR="${SINGULARITY_TMPDIR}/runtime"
export NXF_SINGULARITY_CACHEDIR="${HOME}/singularity_cache"
mkdir -p "${SINGULARITY_TMPDIR}" "${XDG_RUNTIME_DIR}" "${NXF_SINGULARITY_CACHEDIR}"
trap 'rm -rf "${SINGULARITY_TMPDIR}"' EXIT
export CONDA_PREFIX="${HOME}/mambaforge/envs/nextflow"
export PATH="${CONDA_PREFIX}/bin:${PATH}"
unset JAVA_HOME; which singularity
export NXF_SINGULARITY_HOME_MOUNT=true
unset LD_LIBRARY_PATH PYTHONPATH R_LIBS R_LIBS_USER R_LIBS_SITE
